# ==========================================
# Aegis Agent LLM Configuration (Example)
# ==========================================

# 1. 您的 API 密钥 (如 OpenAI, DeepSeek, 火山引擎 Ark 等)
OPENAI_API_KEY="sk-your-api-key-here"

# 2. API 代理地址 (如果是火山引擎填 https://ark.cn-beijing.volces.com/api/v3)
OPENAI_BASE_URL="https://api.openai.com/v1"

# 3. 模型名称或接入点 ID (如 gpt-4o, deepseek-chat, 或 ep-xxx)
MODEL_NAME="your-model-or-endpoint-id"